# Copy this file to .env if you need Docker Compose to pass environment
# variables into the container. .env is ignored by Git.

# Docker build extra dependencies from pyproject.toml.
# Empty means base dependencies only.
# Examples:
#   BUCKSHOT_EXTRAS=llm
#   BUCKSHOT_EXTRAS=openai
#   BUCKSHOT_EXTRAS=openai,deepseek
BUCKSHOT_EXTRAS=

# Add API key environment variables that match provider.api_key_env.
# Example:
#   MY_PROVIDER_API_KEY=replace_me
